    {
      "id": "diagnostic_and_fix_history_circle_distortion",
      "label": "Circle Distortion",
      "file_type": "concept",
      "source_file": "D:\\Python codes\\hmccontroller\\diagnostic_and_fix_history.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Flat lines at cardinal points (axes reversal extremes) during slow path velocity plotting. Disproved mechanical backlash as main cause, found serial timing latency secondary."
    },
    {
      "id": "diagnostic_and_fix_history_firmware_speed_bands_bug",
      "label": "Firmware Speed Bands Bug",
      "file_type": "concept",
      "source_file": "D:\\Python codes\\hmccontroller\\diagnostic_and_fix_history.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Controller firmware systematically overrides commanded speed ranges (16-30 steps/s and 123-244 steps/s) to run up to 12x faster, disrupting coordinated circular interpolation."
    },
    {
      "id": "diagnostic_and_fix_history_serial_state_parser_collision",
      "label": "Serial State Parser Collision",
      "file_type": "rationale",
      "source_file": "D:\\Python codes\\hmccontroller\\diagnostic_and_fix_history.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "The single-axis stepper controller's serial ISR parser collides by checking speed parameter bytes against global command codes (like acceleration/deceleration), causing configurations to abort."
    },
    {
      "id": "diagnostic_and_fix_history_proportional_speed_scaling",
      "label": "Proportional Speed Scaling",
      "file_type": "concept",
      "source_file": "D:\\Python codes\\hmccontroller\\diagnostic_and_fix_history.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Scaling both axis speeds by the same factor k preserves coordinate synchronization and vector slope angles, avoiding warping circle geometry."
    },
    {
      "id": "diagnostic_and_fix_history_fine_grained_calibration",
      "label": "Fine-Grained Calibration",
      "file_type": "concept",
      "source_file": "D:\\Python codes\\hmccontroller\\diagnostic_and_fix_history.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "A 1-step increment sweep from 10 to 250 steps/s over a safe 20 um offset identified exact boundaries of bad bands and minimized necessary scaling factor deviation to 1-2%."
    },
    {
      "id": "diagnostic_and_fix_history_empirical_speed_blacklist",
      "label": "Empirical Speed Blacklist",
      "file_type": "concept",
      "source_file": "D:\\Python codes\\hmccontroller\\diagnostic_and_fix_history.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Determines exact ranges [16, 30] and [123, 244] to bypass speed parser collision using is_bad_speed."
    },
    {
      "id": "diagnostic_and_fix_history_parameter_safety_in_parsers",
      "label": "Parameter Safety in Parsers",
      "file_type": "rationale",
      "source_file": "D:\\Python codes\\hmccontroller\\diagnostic_and_fix_history.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Takeaway: Serial parsers must use strict state tracking (counting expected parameter bytes) rather than globally intercepting all incoming bytes as potential commands."
    },
    {
      "id": "diagnostic_and_fix_history_coordinated_motion_workarounds",
      "label": "Coordinated Motion Workarounds",
      "file_type": "rationale",
      "source_file": "D:\\Python codes\\hmccontroller\\diagnostic_and_fix_history.md",
      "source_location": null,
      "source_url": null,
      "captured_at": null,
      "author": null,
      "contributor": null,
      "rationale": "Takeaway: In decoupled axis systems, speed changes must be proportional across all axes to maintain trajectory angles."
